#!/usr/bin/env bash
# Usage: wallpaper ~/Pictures/wall.jpg
#        wallpaper "#16161e"   (solid color)
set -euo pipefail

TARGET="${1:-}"

if [[ -z "$TARGET" ]]; then
  echo "Usage: wallpaper <path-to-image|#rrggbb>"
  exit 1
fi

if [[ "$TARGET" != \#* && ! -f "$TARGET" ]]; then
  echo "wallpaper: image does not exist: $TARGET" >&2
  exit 1
fi

STATE="$HOME/.config/wallpaper"

# Save for next login
printf '%s\n' "$TARGET" > "$STATE"

# Kill existing swaybg
pkill -x swaybg 2>/dev/null || true
sleep 0.1

# Apply
if [[ "$TARGET" == \#* ]]; then
  nohup swaybg -c "$TARGET" >/tmp/swaybg.log 2>&1 &
else
  nohup swaybg -i "$TARGET" -m fill >/tmp/swaybg.log 2>&1 &
fi

disown
