#!/usr/bin/env bash
set -euo pipefail

STATE="$HOME/.config/wallpaper"
pkill -x swaybg 2>/dev/null || true

if [[ -f "$STATE" ]]; then
  TARGET="$(cat "$STATE")"
  if [[ "$TARGET" == \#* ]]; then
    nohup swaybg -c "$TARGET" >/tmp/swaybg.log 2>&1 &
  elif [[ -f "$TARGET" ]]; then
    nohup swaybg -i "$TARGET" -m fill >/tmp/swaybg.log 2>&1 &
  else
    nohup swaybg -c "#16161e" >/tmp/swaybg.log 2>&1 &
  fi
else
  nohup swaybg -c "#16161e" >/tmp/swaybg.log 2>&1 &
fi
disown
