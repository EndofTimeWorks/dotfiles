#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

failed=0

check() {
  local label="$1"
  shift

  printf 'checking %s... ' "$label"
  if "$@"; then
    echo ok
  else
    echo failed
    failed=1
  fi
}

check "Git whitespace" git diff --check
check "Niri configuration" niri validate -c apps/.config/niri/config.kdl

if command -v qmllint >/dev/null 2>&1; then
  while IFS= read -r qml; do
    check "QML: $qml" qmllint "$qml"
  done < <(find apps/.config/quickshell -type f -name '*.qml' -print | sort)
fi

if command -v fish >/dev/null 2>&1; then
  check "Fish configuration" fish -n \
    fish/.config/fish/config.fish \
    fish/.config/fish/conf.d/colors.fish
fi

if command -v wezterm >/dev/null 2>&1; then
  check "WezTerm configuration" bash -c \
    'wezterm --config-file apps/.config/wezterm/wezterm.lua show-keys --lua >/dev/null'
fi

if command -v jq >/dev/null 2>&1; then
  check "JSON configuration" jq empty \
    apps/.config/ags/package.json \
    apps/.config/vicinae/settings.json \
    apps/.config/zed/keymap.json \
    apps/.config/zed/themes/zed.json
fi

check "stale checkout paths" bash -c \
  '! git grep -nE "/home/end/(Github|projects)/dotfiles" -- ":(exclude)README.md"'

required_commands=(
  brightnessctl discord helium-browser hyprlock niri notify-send obsidian
  playerctl playerctld qpwgraph quickshell rfkill signal-desktop swayidle
  thunderbird upower vicinae wallpaper-init wezterm zeditor zen-browser
)
for command_name in "${required_commands[@]}"; do
  check "runtime command: $command_name" command -v "$command_name"
done

check "Plasma files are non-executable" bash -c \
  '! find plasma -type f -perm /111 -print -quit | grep -q .'

if command -v stow >/dev/null 2>&1; then
  check "Stow simulation" stow --no --verbose=1 apps fish
fi

for script in apps/.local/bin/* scripts/*; do
  [[ -f "$script" ]] || continue
  [[ "$(head -n 1 "$script")" == *bash* ]] || continue
  check "shell syntax: $script" bash -n "$script"
done

if command -v shellcheck >/dev/null 2>&1; then
  mapfile -t shell_scripts < <(
    for script in apps/.local/bin/* scripts/*; do
      [[ -f "$script" ]] || continue
      [[ "$(head -n 1 "$script")" == *bash* ]] && printf '%s\n' "$script"
    done
  )
  check "ShellCheck" shellcheck "${shell_scripts[@]}"
fi

if command -v systemd-analyze >/dev/null 2>&1; then
  while IFS= read -r unit; do
    check "systemd unit: $unit" systemd-analyze verify "$unit"
  done < <(find apps/.config/systemd system/systemd -type f \( -name '*.service' -o -name '*.timer' \) -print | sort)
fi

if nix store ping --store daemon >/dev/null 2>&1; then
  check "Home Manager evaluation" \
    nix build --no-link "path:${repo_root}#homeConfigurations.end.activationPackage"
else
  echo "skipping Home Manager evaluation: Nix daemon is unavailable"
fi

exit "$failed"
